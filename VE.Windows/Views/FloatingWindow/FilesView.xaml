<UserControl x:Class="VE.Windows.Views.FloatingWindow.FilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with upload buttons -->
        <Border Grid.Row="0" Padding="16,10" BorderThickness="0,0,0,1"
                BorderBrush="#1AFFFFFF">
            <Grid>
                <TextBlock Text="Knowledge Base" Foreground="White" FontSize="15"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+ URL" Style="{StaticResource VEGhostButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,6,0"
                            Click="AddUrl_Click" />
                    <Button Content="+ File" Style="{StaticResource VEButton}"
                            Padding="10,4" FontSize="11"
                            Click="AddFile_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- File List -->
        <Grid Grid.Row="1">
            <TextBlock x:Name="LoadingText" Text="Loading files..."
                       Foreground="#878E92" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,40,0,0" />

            <TextBlock x:Name="EmptyText" Text="No files uploaded yet"
                       Foreground="#878E92" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,40,0,0"
                       Visibility="Collapsed" />

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="FilesList" Margin="8,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0DFFFFFF" CornerRadius="8"
                                    Padding="12,10" Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Type Badge -->
                                    <Border Grid.Column="0" Background="#1A007CEC"
                                            CornerRadius="4" Padding="6,3" Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TypeIcon}" Foreground="#007CEC"
                                                   FontSize="9" FontWeight="Bold" />
                                    </Border>

                                    <!-- File Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding OriginalFileName}" Foreground="#F4F5F5"
                                                   FontSize="12" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Status}" Foreground="#878E92"
                                                       FontSize="10" />
                                            <TextBlock Text=" · " Foreground="#555" FontSize="10" />
                                            <TextBlock Text="{Binding FormattedDate}" Foreground="#555"
                                                       FontSize="10" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Delete -->
                                    <Button Grid.Column="2" Content="&#x2715;"
                                            Foreground="#FF4444" FontSize="10"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="4,2"
                                            VerticalAlignment="Center"
                                            Click="DeleteFile_Click" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
