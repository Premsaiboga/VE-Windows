<UserControl x:Class="VE.Windows.Views.FloatingWindow.FilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             Drop="UploadZone_Drop"
             DragEnter="UploadZone_DragEnter"
             DragLeave="UploadZone_DragLeave"
             DragOver="UploadZone_DragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Main scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Margin="16,12,16,16">

                <!-- Title -->
                <TextBlock Text="Knowledge Base" Foreground="{DynamicResource ThemeTextPrimary}"
                           FontSize="18" FontWeight="Medium" Margin="0,0,0,16" />

                <!-- Upload Zone -->
                <Border x:Name="UploadZoneBorder" MinHeight="180" CornerRadius="12"
                        Background="Transparent" Margin="0,0,0,20"
                        BorderThickness="1.5" Cursor="Hand"
                        MouseLeftButtonDown="UploadZone_Click">
                    <Border.BorderBrush>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Rectangle Width="100" Height="100"
                                           StrokeDashArray="6 4" StrokeThickness="1.5"
                                           Stroke="{DynamicResource ThemeBorder}"
                                           RadiusX="12" RadiusY="12" />
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.BorderBrush>

                    <Grid>
                        <!-- Normal upload content -->
                        <StackPanel x:Name="UploadContent" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Margin="20">
                            <TextBlock Text="&#x2B06;" FontSize="36" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,12" />
                            <TextBlock Text="Drag and drop files to upload" FontSize="15" FontWeight="Medium"
                                       Foreground="{DynamicResource ThemeTextSecondary}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6" />
                            <TextBlock Text="PDF, DOCX, TXT, MD, JPG, PNG, JSON, CSV, XLS, XLSX"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource ThemeTextSecondary}" Opacity="0.7"
                                       HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <Border HorizontalAlignment="Center" CornerRadius="20"
                                    BorderThickness="1.5" BorderBrush="#007CEC"
                                    Background="Transparent" Padding="20,10"
                                    Cursor="Hand" MouseLeftButtonDown="ChooseFiles_Click">
                                <TextBlock Text="Choose Files" Foreground="#007CEC"
                                           FontSize="14" FontWeight="Medium" />
                            </Border>
                        </StackPanel>

                        <!-- Uploading spinner -->
                        <StackPanel x:Name="UploadingContent" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock x:Name="SpinnerText" Text="&#x23F3;" FontSize="28"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"
                                       Foreground="{DynamicResource ThemeTextSecondary}">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotation" CenterX="0.5" CenterY="0.5" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="Uploading document..." FontSize="15" FontWeight="Medium"
                                       Foreground="{DynamicResource ThemeTextSecondary}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Toast notification area -->
                <Border x:Name="ToastBorder" Visibility="Collapsed" CornerRadius="10"
                        Background="{DynamicResource ThemeCard}" Padding="12,10" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="8" ShadowDepth="4" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ToastIcon" Grid.Column="0" FontSize="16" VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock x:Name="ToastMessage" Grid.Column="1" FontSize="13"
                                   Foreground="{DynamicResource ThemeTextPrimary}"
                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="2" Text="&#x2715;" FontSize="12" Cursor="Hand"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   MouseLeftButtonDown="CloseToast_Click" />
                    </Grid>
                </Border>

                <!-- Shimmer loading skeleton -->
                <StackPanel x:Name="ShimmerPanel" Visibility="Collapsed">
                    <Border Background="{DynamicResource ThemeCard}" Width="80" Height="13"
                            CornerRadius="4" HorizontalAlignment="Left" Margin="0,0,0,8" Opacity="0.6" />
                    <Border Background="{DynamicResource ThemeCard}" CornerRadius="10" Padding="12,4" Margin="0,0,0,4">
                        <StackPanel>
                            <Grid Height="40" Margin="0,6">
                                <Border Background="{DynamicResource ThemeBorder}" Width="28" Height="28"
                                        CornerRadius="6" HorizontalAlignment="Left" Opacity="0.4" />
                                <Border Background="{DynamicResource ThemeBorder}" Height="14"
                                        CornerRadius="4" HorizontalAlignment="Stretch" Margin="40,0,60,0" Opacity="0.3" />
                            </Grid>
                            <Grid Height="40" Margin="0,6">
                                <Border Background="{DynamicResource ThemeBorder}" Width="28" Height="28"
                                        CornerRadius="6" HorizontalAlignment="Left" Opacity="0.4" />
                                <Border Background="{DynamicResource ThemeBorder}" Height="14"
                                        CornerRadius="4" HorizontalAlignment="Stretch" Margin="40,0,100,0" Opacity="0.3" />
                            </Grid>
                            <Grid Height="40" Margin="0,6">
                                <Border Background="{DynamicResource ThemeBorder}" Width="28" Height="28"
                                        CornerRadius="6" HorizontalAlignment="Left" Opacity="0.4" />
                                <Border Background="{DynamicResource ThemeBorder}" Height="14"
                                        CornerRadius="4" HorizontalAlignment="Stretch" Margin="40,0,80,0" Opacity="0.3" />
                            </Grid>
                            <Grid Height="40" Margin="0,6">
                                <Border Background="{DynamicResource ThemeBorder}" Width="28" Height="28"
                                        CornerRadius="6" HorizontalAlignment="Left" Opacity="0.4" />
                                <Border Background="{DynamicResource ThemeBorder}" Height="14"
                                        CornerRadius="4" HorizontalAlignment="Stretch" Margin="40,0,120,0" Opacity="0.3" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyText" Text="No files uploaded yet"
                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,20,0,0"
                           Visibility="Collapsed" />

                <!-- File list grouped by date -->
                <ItemsControl x:Name="FileGroupsList" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
