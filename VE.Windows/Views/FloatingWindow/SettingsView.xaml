<UserControl x:Class="VE.Windows.Views.FloatingWindow.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SettingsNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextTertiary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource ThemeHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileField" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeCard}" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMedium}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource ThemeBg2}" CornerRadius="12" ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Back to home header -->
        <Border Grid.Row="0" Padding="16,10" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
            <Button Style="{StaticResource SettingsNavButton}"
                    HorizontalAlignment="Left" Click="BackToHome_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2190;" FontSize="14" Foreground="{DynamicResource ThemeTextTertiary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Back to home" Foreground="{DynamicResource ThemeTextTertiary}" FontSize="13" />
                </StackPanel>
            </Button>
        </Border>

        <!-- Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Settings Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0"
                    CornerRadius="0,0,0,12">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="8,0,8,0">
                        <Button x:Name="NavProfile" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="profile"
                                Foreground="{DynamicResource ThemeTextPrimary}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2699;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="My profile" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavWorkspace" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="workspace">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4BC;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Workspace" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavTeam" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="team">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F465;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Team Members" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavConnectors" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="connectors">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F517;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Workspace Connectors" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSubscription" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="subscription">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4B3;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Subscription" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavRefer" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="refer">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F381;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Refer &amp; Earn" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavAbout" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="about">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2139;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="About" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavHelp" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="help">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2753;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Help center" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavTerms" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="terms">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C4;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Terms of use" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavPrivacy" Style="{StaticResource SettingsNavButton}"
                                Click="SettingsNav_Click" Tag="privacy">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F512;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Privacy policy" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- My Profile Content (default) -->
                    <StackPanel x:Name="ProfileContent" Margin="32,20,32,20">
                        <!-- Avatar -->
                        <Border HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Grid>
                                <Border Width="100" Height="100" CornerRadius="50"
                                        BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="2">
                                    <TextBlock x:Name="AvatarInitials" Text="PB"
                                               Foreground="{DynamicResource ThemeTextPrimary}" FontSize="36"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Border Width="24" Height="24" CornerRadius="12"
                                        Background="{DynamicResource ThemeCard}" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,4,4" Cursor="Hand">
                                    <TextBlock Text="&#x270F;" FontSize="10" Foreground="{DynamicResource ThemeTextTertiary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Your Name -->
                        <TextBlock Text="Your Name" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="NameField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,18" />

                        <!-- Your Contact Number -->
                        <TextBlock Text="Your Contact Number" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="PhoneField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,18" />

                        <!-- Your Primary Email -->
                        <TextBlock Text="Your Primary Email" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,18">
                            <TextBox x:Name="EmailField" Style="{StaticResource ProfileField}"
                                     IsReadOnly="True" />
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="22" Height="22" CornerRadius="11"
                                    Background="Transparent" Margin="0,0,12,0">
                                <TextBlock Text="&#x2705;" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>

                        <!-- Your Profession -->
                        <TextBlock x:Name="ProfessionLabel" Text="Your Profession In workspace"
                                   Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="ProfessionField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,24" />

                        <!-- Notifications Banner -->
                        <Border Background="#1A007CEC" CornerRadius="10"
                                BorderBrush="#33007CEC" BorderThickness="1"
                                Padding="16,12" Margin="0,0,0,18">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#x1F514;" FontSize="16"
                                               VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <StackPanel>
                                        <TextBlock Text="Notifications are off" Foreground="{DynamicResource ThemeTextPrimary}"
                                                   FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="Enable to receive meeting reminders and important updates."
                                                   Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <Button Content="Open Settings" Style="{StaticResource VEButton}"
                                        Padding="14,7" FontSize="12"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Leave Workspace -->
                        <Border Background="#1AFF4B59" CornerRadius="10"
                                BorderBrush="#33FF4B59" BorderThickness="1"
                                Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Do you want to leave your workspace?"
                                           Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBlock Text="When you leave your workspace, your work will be lost, and your team will be notified. Select a workspace you would like to leave."
                                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,14" />
                                <Border Background="#33FF4B59" CornerRadius="8"
                                        Padding="0,10" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x2192;" Foreground="#FF4B59" FontSize="13"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="Leave workspace" Foreground="#FF4B59"
                                                   FontSize="13" FontWeight="Medium" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Workspace Content -->
                    <StackPanel x:Name="WorkspaceContent" Visibility="Collapsed"
                                Margin="32,20,32,20">
                        <!-- Workspace Avatar -->
                        <Border HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Grid>
                                <Border Width="100" Height="100" CornerRadius="50"
                                        BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="2">
                                    <TextBlock x:Name="WorkspaceIcon" Text="&#x1F3E2;"
                                               Foreground="{DynamicResource ThemeTextTertiary}" FontSize="36"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Border Width="24" Height="24" CornerRadius="12"
                                        Background="{DynamicResource ThemeCard}" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,4,4" Cursor="Hand">
                                    <TextBlock Text="&#x270F;" FontSize="10" Foreground="{DynamicResource ThemeTextTertiary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Business Name -->
                        <TextBlock Text="Business Name" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="BusinessNameField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,18" />

                        <!-- Company Email -->
                        <TextBlock Text="Company Email" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="CompanyEmailField" Style="{StaticResource ProfileField}"
                                 IsReadOnly="True" Margin="0,0,0,18" />

                        <!-- Website -->
                        <TextBlock Text="Website" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="WebsiteField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,18" />

                        <!-- Company Type -->
                        <TextBlock Text="Company type" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="CompanyTypeField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,18" />

                        <!-- Phone Number -->
                        <TextBlock Text="Phone Number" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="WorkspacePhoneField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,18" />

                        <!-- Address -->
                        <TextBlock Text="Address" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="AddressField" Style="{StaticResource ProfileField}"
                                 Margin="0,0,0,24" />
                    </StackPanel>

                    <!-- Team Members Content -->
                    <StackPanel x:Name="TeamContent" Visibility="Collapsed"
                                Margin="32,20,32,20">
                        <!-- Title + count -->
                        <TextBlock x:Name="TeamTitle" Text="Manage Your Team Members Access"
                                   Foreground="{DynamicResource ThemeTextPrimary}" FontSize="20"
                                   FontWeight="SemiBold" Margin="0,0,0,16" />

                        <!-- Invite input -->
                        <Border Background="{DynamicResource ThemeCard}" CornerRadius="8"
                                BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                Padding="4,0" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x1F464;" FontSize="14"
                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"
                                           Margin="10,0,8,0" />
                                <TextBox x:Name="InviteEmailField" Grid.Column="1"
                                         Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}"
                                         FontSize="13" BorderThickness="0"
                                         Padding="4,10" CaretBrush="{DynamicResource ThemeTextPrimary}"
                                         KeyDown="InviteEmail_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBlock x:Name="placeholder"
                                                                       Text="Add name or Email"
                                                                       Foreground="{DynamicResource ThemeTextMuted}"
                                                                       FontSize="13"
                                                                       VerticalAlignment="Center"
                                                                       Margin="6,0,0,0"
                                                                       Visibility="Collapsed" />
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                          VerticalAlignment="Center" />
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter TargetName="placeholder"
                                                                        Property="Visibility"
                                                                        Value="Visible" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Border>

                        <!-- Loading text -->
                        <TextBlock x:Name="TeamLoadingText" Text="Loading team members..."
                                   Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,20,0,0" />

                        <!-- Members list -->
                        <ItemsControl x:Name="TeamMembersList" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,10" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar circle -->
                                            <Border Grid.Column="0" Width="38" Height="38"
                                                    CornerRadius="19" Background="#2A8C8C"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Initials}"
                                                           Foreground="White" FontSize="13"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name + email -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ThemeTextPrimary}"
                                                           FontSize="13" FontWeight="Medium" />
                                                <TextBlock Text="{Binding Email}" Foreground="{DynamicResource ThemeTextSecondary}"
                                                           FontSize="11" Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Role -->
                                            <TextBlock Grid.Column="2" Text="{Binding RoleDisplay}"
                                                       FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{Binding RoleBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Subscription Content -->
                    <StackPanel x:Name="SubscriptionContent" Visibility="Collapsed"
                                Margin="32,20,32,20">

                        <!-- Plan Card -->
                        <Border CornerRadius="12" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                Padding="24,20" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="PlanNameText" Text="Free"
                                           Foreground="#007CEC" FontSize="24"
                                           FontWeight="Bold" Margin="0,0,0,4" />
                                <TextBlock Text="Current plan" Foreground="{DynamicResource ThemeTextPrimary}"
                                           FontSize="14" FontWeight="Medium"
                                           Margin="0,0,0,4" />
                                <TextBlock x:Name="PlanExpiryText" Text=""
                                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                                           Margin="0,0,0,16" />

                                <!-- Buttons -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Border CornerRadius="8" BorderBrush="{DynamicResource ThemeBorderStrong}"
                                            BorderThickness="1" Padding="18,8"
                                            Margin="0,0,10,0" Cursor="Hand">
                                        <TextBlock Text="Manage billing" Foreground="{DynamicResource ThemeTextPrimary}"
                                                   FontSize="13" />
                                    </Border>
                                    <Border CornerRadius="8" Background="#007CEC"
                                            Padding="24,8" Cursor="Hand">
                                        <TextBlock Text="Upgrade" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Team Members Usage -->
                        <Border CornerRadius="12" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                Padding="24,16" Margin="0,16,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="TEAM MEMBERS" Foreground="{DynamicResource ThemeTextPrimary}"
                                               FontSize="13" FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="SeatsUsedText" Text="0"
                                                   Foreground="{DynamicResource ThemeTextPrimary}" FontSize="22"
                                                   FontWeight="Bold" />
                                        <TextBlock x:Name="SeatsTotalText" Text=" used / 0"
                                                   Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                                                   VerticalAlignment="Bottom"
                                                   Margin="0,0,0,2" />
                                    </StackPanel>
                                </Grid>

                                <!-- Progress bar -->
                                <Grid Height="4" Margin="0,0,0,6">
                                    <Border Background="{DynamicResource ThemeCard}" CornerRadius="2" />
                                    <Border x:Name="SeatsProgressBar" Background="#FF4B59"
                                            CornerRadius="2" HorizontalAlignment="Left"
                                            Width="0" />
                                </Grid>

                                <TextBlock x:Name="SeatsStatusText" Text=""
                                           Foreground="#FF4B59" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Referral Code Card -->
                        <Border CornerRadius="12" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                Padding="24,20" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Have a referral code?" Foreground="{DynamicResource ThemeTextPrimary}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Referral credits apply to invoices following your initial payment"
                                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="12"
                                           Margin="0,0,0,14" />

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ReferralCodeField"
                                             Style="{StaticResource ProfileField}"
                                             Grid.Column="0" Margin="0,0,10,0" />
                                    <Border Grid.Column="1" CornerRadius="8"
                                            Background="#333D6B" Padding="20,9"
                                            Cursor="Hand">
                                        <TextBlock Text="Apply" Foreground="#A0A8CC"
                                                   FontSize="13" />
                                    </Border>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Want Ve for your team or business? "
                                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="12" />
                                    <TextBlock Text="Contact us &#x2197;"
                                               Foreground="#007CEC" FontSize="12"
                                               Cursor="Hand" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Placeholder for other sections -->
                    <StackPanel x:Name="PlaceholderContent" Visibility="Collapsed"
                                Margin="32,40" HorizontalAlignment="Center">
                        <TextBlock x:Name="PlaceholderTitle" Text="" Foreground="{DynamicResource ThemeTextPrimary}"
                                   FontSize="20" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="PlaceholderSubtitle" Text="Coming soon"
                                   Foreground="{DynamicResource ThemeTextSecondary}" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
    </Border>
</UserControl>
