<UserControl x:Class="VE.Windows.Views.FloatingWindow.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VE.Windows.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
                BorderBrush="#1AFFFFFF">
            <Grid>
                <TextBlock Text="Chat with VE"
                           Foreground="White" FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Content="Clear"
                        HorizontalAlignment="Right"
                        Style="{StaticResource VEGhostButton}"
                        Click="ClearChat_Click" />
            </Grid>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,8">
            <ItemsControl x:Name="MessagesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4,0,4">
                            <!-- User message -->
                            <Border HorizontalAlignment="Right" MaxWidth="300"
                                    Background="#007CEC" CornerRadius="12,12,4,12"
                                    Padding="12,8"
                                    Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Content}"
                                           Foreground="White" FontSize="13"
                                           TextWrapping="Wrap" />
                            </Border>
                            <!-- Assistant message -->
                            <Border HorizontalAlignment="Left" MaxWidth="340"
                                    Background="#25292D" CornerRadius="12,12,12,4"
                                    Padding="12,8"
                                    Visibility="{Binding IsAssistant, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Content}"
                                           Foreground="#F4F5F5" FontSize="13"
                                           TextWrapping="Wrap" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Welcome (when no messages) -->
        <StackPanel x:Name="WelcomePanel" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Visible">
            <TextBlock Text="Ask VE anything"
                       Foreground="#878E92" FontSize="18"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="AI assistant for your work"
                       Foreground="#555" FontSize="13"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Input Bar -->
        <Border Grid.Row="2" Padding="12" BorderThickness="0,1,0,0"
                BorderBrush="#1AFFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="ChatInput"
                         Grid.Column="0"
                         Style="{StaticResource VETextBox}"
                         Foreground="White"
                         BorderBrush="#33FFFFFF"
                         KeyDown="ChatInput_KeyDown"
                         VerticalAlignment="Center" />

                <Button Grid.Column="1" Content="&#x27A4;"
                        FontSize="16"
                        Style="{StaticResource VEButton}"
                        Width="36" Height="36"
                        Padding="0"
                        Margin="8,0,0,0"
                        Click="SendButton_Click" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
