<UserControl x:Class="VE.Windows.Views.FloatingWindow.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VE.Windows.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Sidebar button style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextTertiary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource ThemeHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Recent chat item style -->
        <Style x:Key="RecentChatButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <!-- Toggle button style -->
        <Style x:Key="ToggleTabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Theme icon button -->
        <Style x:Key="ThemeIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource ThemeHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Workspace list item button -->
        <Style x:Key="WorkspaceItemButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Padding" Value="10,8" />
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <!-- Layer 0: Main Layout (Sidebar + Content) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="210" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT SIDEBAR ═══ -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0"
                    CornerRadius="12,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ─── CHAT SIDEBAR (visible in Chat mode) ─── -->
                    <Grid x:Name="ChatSidebar" Grid.Row="0">
                        <StackPanel VerticalAlignment="Center" Margin="8,0,8,0">
                            <Button Style="{StaticResource SidebarButton}" Click="NewChat_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="15" Foreground="{DynamicResource ThemeTextTertiary}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="New Chat" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Click="Integrations_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2630;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Integrations" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <TextBlock Text="Recent" Foreground="{DynamicResource ThemeTextMuted}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Margin="12,16,0,6" />

                            <ScrollViewer x:Name="RecentChatsScroll"
                                          VerticalScrollBarVisibility="Hidden"
                                          MaxHeight="200"
                                          ScrollChanged="RecentChatsScroll_ScrollChanged">
                                <StackPanel>
                                    <ItemsControl x:Name="RecentChatsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource RecentChatButton}"
                                                        Click="RecentChat_Click" Tag="{Binding Id}">
                                                    <TextBlock Text="{Binding Title}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="170" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="LoadingMoreText" Text="Loading..."
                                               Foreground="{DynamicResource ThemeTextMuted}" FontSize="11"
                                               HorizontalAlignment="Center"
                                               Margin="0,4" Visibility="Collapsed" />
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>

                    <!-- ─── WORK SIDEBAR (visible in Work mode) ─── -->
                    <Grid x:Name="WorkSidebar" Grid.Row="0" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" Margin="8,0,8,0">
                        <Button x:Name="WorkNavNotes" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Notes" Foreground="{DynamicResource ThemeTextPrimary}" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4DD;" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Notes" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavMails" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Mail">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2709;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Mails" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavPrediction" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Prediction">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2728;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Prediction" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavRoutines" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Routines">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F504;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Routines" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavIntentModel" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="IntentModel">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CB;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Intent Model" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavFiles" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Knowledge">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C1;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Files" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavShared" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Shared">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F465;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Shared with me" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavConnectors" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Connectors">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F517;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Connectors" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkNavShortcuts" Style="{StaticResource SidebarButton}"
                                Click="WorkNav_Click" Tag="Shortcuts">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2328;" FontSize="13" Foreground="{DynamicResource ThemeTextTertiary}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Shortcuts" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </Grid>

                    <!-- ─── BOTTOM: User Profile (shared between Chat/Work) ─── -->
                    <Border Grid.Row="1" Padding="10,8" Margin="0,4,0,0"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0"
                            Cursor="Hand" MouseLeftButtonDown="UserProfile_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="32" Height="32"
                                    CornerRadius="16" Background="#007CEC"
                                    Margin="0,0,8,0">
                                <TextBlock x:Name="UserInitials" Text="PB"
                                           Foreground="White" FontSize="12"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="UserWorkspaceText" Text=""
                                           Foreground="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                           FontWeight="Medium"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="UserNameText" Text="User"
                                           Foreground="{DynamicResource ThemeTextMuted}" FontSize="10"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#x25C7;" Foreground="{DynamicResource ThemeTextMuted}" FontSize="9"
                                           VerticalAlignment="Center" Margin="4,0" />
                                <Button Content="&#x2699;" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="14"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="4,0"
                                        Click="SettingsGear_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Chat / Work Toggle -->
                <Border Grid.Row="0" Padding="0,12,0,8">
                    <Border HorizontalAlignment="Center" Background="{DynamicResource ThemeCard}"
                            CornerRadius="16" Padding="3">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ToggleChat" Content="Chat"
                                    Style="{StaticResource ToggleTabButton}"
                                    Background="#007CEC" Foreground="White"
                                    Click="ToggleChat_Click" />
                            <Button x:Name="ToggleWork" Content="Work"
                                    Style="{StaticResource ToggleTabButton}"
                                    Click="ToggleWork_Click" />
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Messages ScrollViewer -->
                <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,4">
                    <ItemsControl x:Name="MessagesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,4">
                                    <!-- User message -->
                                    <Border HorizontalAlignment="Right" MaxWidth="340"
                                            Background="#007CEC" CornerRadius="14,14,4,14"
                                            Padding="14,9"
                                            Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding Content}"
                                                   Foreground="White" FontSize="13"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                    <!-- Assistant message -->
                                    <Border HorizontalAlignment="Left" MaxWidth="380"
                                            Background="{DynamicResource ThemeCard}" CornerRadius="14,14,14,4"
                                            Padding="14,9"
                                            Visibility="{Binding IsAssistant, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding Content}"
                                                   Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Welcome Panel (when no messages) -->
                <StackPanel x:Name="WelcomePanel" Grid.Row="1"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="24,0">
                    <TextBlock x:Name="GreetingName" Text="Hey there,"
                               Foreground="{DynamicResource ThemeTextPrimary}" FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="how are you feeling today?"
                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="18"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />

                    <!-- Suggestion Chips (below greeting) -->
                    <StackPanel Margin="0,28,0,0" HorizontalAlignment="Center">
                        <Border Background="#007CEC" CornerRadius="14"
                                Padding="16,12" Margin="0,0,0,8"
                                Cursor="Hand" MouseLeftButtonDown="Suggestion_Click"
                                Tag="I have a few questions. Would you mind answering them?">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4A1;" FontSize="14"
                                           VerticalAlignment="Top" Margin="0,0,8,0" />
                                <TextBlock TextWrapping="Wrap" MaxWidth="260">
                                    <Run Text="I have a few questions." FontWeight="SemiBold"
                                         Foreground="White" />
                                    <LineBreak />
                                    <Run Text="Would you mind answering them?"
                                         Foreground="#CCFFFFFF" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Work Mode Content (embedded views) -->
                <ContentControl x:Name="WorkContent" Grid.Row="1"
                                ClipToBounds="True"
                                Visibility="Collapsed" />

                <!-- Input Bar (hidden in Work mode) -->
                <Border x:Name="InputBar" Grid.Row="2" Padding="14,8,14,14">
                    <Border Background="{DynamicResource ThemeCard}" CornerRadius="12"
                            BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                            Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Text Input -->
                            <TextBox x:Name="ChatInput" Grid.Row="0"
                                     Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}"
                                     FontSize="13" BorderThickness="0"
                                     Padding="10,8"
                                     VerticalContentAlignment="Center"
                                     AcceptsReturn="False"
                                     KeyDown="ChatInput_KeyDown" />

                            <!-- Bottom Row: Attach + Send -->
                            <Grid Grid.Row="1" Margin="4,2,4,4">
                                <!-- + Button (opens options popup) -->
                                <Border HorizontalAlignment="Left"
                                        Background="{DynamicResource ThemeHover}" CornerRadius="8"
                                        Cursor="Hand" Padding="8,4"
                                        MouseLeftButtonDown="PlusButton_Click">
                                    <TextBlock Text="+" Foreground="{DynamicResource ThemeTextTertiary}"
                                               FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <!-- Send Button -->
                                <Border HorizontalAlignment="Right"
                                        Background="#007CEC" CornerRadius="8"
                                        Cursor="Hand" Padding="10,5"
                                        MouseLeftButtonDown="SendButton_Click">
                                    <TextBlock Text="&#x2191;" Foreground="White"
                                               FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Border>

                <!-- ═══ PLUS MENU POPUP (above input bar) ═══ -->
                <Border x:Name="PlusMenuPopup" Grid.Row="1"
                        Visibility="Collapsed"
                        VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="20,0,0,8"
                        Background="{DynamicResource ThemePopupBg}" CornerRadius="14"
                        BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                        Width="280" Panel.ZIndex="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.6" ShadowDepth="4" />
                    </Border.Effect>
                    <StackPanel>
                        <!-- Model selector row -->
                        <Border Padding="14,12" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1"
                                Cursor="Hand" MouseLeftButtonDown="ModelSelector_Click">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ve" Foreground="#007CEC" FontSize="14"
                                               FontWeight="Bold" FontStyle="Italic"
                                               VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock x:Name="SelectedModelName" Text="Ve"
                                               Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                               FontWeight="Medium" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="&#x203A;" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="18"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Upload file -->
                        <Border Padding="14,12" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C4;" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Upload file" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Search web toggle -->
                        <Border Padding="14,10" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F310;" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Text="Search web" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Search web for latest information"
                                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                               Margin="24,2,0,0" />
                                </StackPanel>
                                <Border x:Name="ToggleSearchWeb" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Width="40" Height="22"
                                        CornerRadius="11" Background="#007CEC" Cursor="Hand"
                                        MouseLeftButtonDown="ToggleSearchWeb_Click">
                                    <Border x:Name="SearchWebKnob" Width="18" Height="18"
                                            CornerRadius="9" Background="White"
                                            HorizontalAlignment="Right" Margin="2" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Internal Knowledge toggle -->
                        <Border Padding="14,10" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F4DA;" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Text="Internal Knowledge" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Search internal knowledge base"
                                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                               Margin="24,2,0,0" />
                                </StackPanel>
                                <Border x:Name="ToggleInternalKnowledge" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Width="40" Height="22"
                                        CornerRadius="11" Background="#007CEC" Cursor="Hand"
                                        MouseLeftButtonDown="ToggleInternalKnowledge_Click">
                                    <Border x:Name="InternalKnowledgeKnob" Width="18" Height="18"
                                            CornerRadius="9" Background="White"
                                            HorizontalAlignment="Right" Margin="2" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Deep Search toggle -->
                        <Border Padding="14,10">
                            <Grid>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F50D;" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Text="Deep Search" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="In-depth research and analysis"
                                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                               Margin="24,2,0,0" />
                                </StackPanel>
                                <Border x:Name="ToggleDeepSearch" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Width="40" Height="22"
                                        CornerRadius="11" Background="{DynamicResource ThemeTextMuted}" Cursor="Hand"
                                        MouseLeftButtonDown="ToggleDeepSearch_Click">
                                    <Border x:Name="DeepSearchKnob" Width="18" Height="18"
                                            CornerRadius="9" Background="White"
                                            HorizontalAlignment="Left" Margin="2" />
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ MODEL SELECTOR POPUP ═══ -->
                <Border x:Name="ModelSelectorPopup" Grid.Row="1"
                        Visibility="Collapsed"
                        VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="20,0,0,8"
                        Background="{DynamicResource ThemePopupBg}" CornerRadius="14"
                        BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                        Width="260" Panel.ZIndex="25">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.6" ShadowDepth="4" />
                    </Border.Effect>
                    <ItemsControl x:Name="ModelList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,11" Cursor="Hand"
                                        MouseLeftButtonDown="ModelItem_Click"
                                        Tag="{Binding Id}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Checkmark for selected -->
                                            <TextBlock Text="&#x2713;" Foreground="#007CEC"
                                                       FontSize="13" FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                                            <!-- Icon -->
                                            <TextBlock Text="{Binding Icon}" FontSize="13"
                                                       Foreground="#007CEC" FontWeight="Bold"
                                                       FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <!-- Name -->
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource ThemeTextPrimary}"
                                                       FontSize="14" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <!-- Default badge -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Background="{DynamicResource ThemeCard}" CornerRadius="4" Padding="8,3"
                                                Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Default" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="10" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ SETTINGS VIEW OVERLAY ═══ -->
        <ContentControl x:Name="SettingsOverlay" Visibility="Collapsed" />

        <!-- ═══ ACCOUNT POPUP OVERLAY ═══ -->
        <Grid x:Name="AccountOverlay" Visibility="Collapsed">
            <!-- Semi-transparent backdrop -->
            <Border Background="{DynamicResource ThemeOverlay}" MouseLeftButtonDown="CloseAccountPopup_Click" />

            <!-- Popup Card -->
            <Border x:Name="AccountPopup"
                    VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Width="270" Margin="10,0,0,56"
                    Background="{DynamicResource ThemePopupBg}" CornerRadius="14"
                    BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.6" ShadowDepth="6" />
                </Border.Effect>

                <StackPanel>
                    <!-- Theme Toggle -->
                    <Border Padding="16,14,16,10">
                        <Border HorizontalAlignment="Center" Background="{DynamicResource ThemeCard}"
                                CornerRadius="12" Padding="4,3">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ThemeSystem" Content="&#x1F5B5;"
                                        Style="{StaticResource ThemeIconButton}"
                                        Background="#007CEC" Foreground="White"
                                        Click="ThemeSystem_Click" />
                                <Button x:Name="ThemeLight" Content="&#x2600;"
                                        Style="{StaticResource ThemeIconButton}"
                                        Click="ThemeLight_Click" />
                                <Button x:Name="ThemeDark" Content="&#x1F319;"
                                        Style="{StaticResource ThemeIconButton}"
                                        Click="ThemeDark_Click" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Workspace Card -->
                    <Border Margin="12,0,12,0" Background="{DynamicResource ThemeCard}" CornerRadius="10"
                            Padding="14,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="17"
                                        Background="#007CEC" Margin="0,0,10,0">
                                    <TextBlock x:Name="WorkspaceInitial" Text="V"
                                               Foreground="White" FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="PopupWorkspaceName" Text=""
                                               Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="PopupWorkspaceDetail" Text=""
                                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Intent Score Bar -->
                            <Border Margin="0,10,0,0" Background="{DynamicResource ThemeBg2}" CornerRadius="12"
                                    Padding="12,7">
                                <Grid>
                                    <TextBlock Text="Your Intent score" Foreground="#00CA48"
                                               FontSize="11" FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="IntentScoreText" Text="--"
                                               Foreground="#00CA48" FontSize="12"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Invite Teammates -->
                    <Border Margin="12,8,12,0" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                            CornerRadius="10" Padding="0">
                        <Button Style="{StaticResource SidebarButton}"
                                HorizontalContentAlignment="Center" Padding="12,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F465;" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Invite teammates" Foreground="{DynamicResource ThemeTextPrimary}"
                                           FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Divider -->
                    <Border Height="1" Background="{DynamicResource ThemeHover}" Margin="12,10" />

                    <!-- All Workspaces -->
                    <TextBlock Text="All workspaces" Foreground="#007CEC" FontSize="12"
                               FontWeight="SemiBold" Margin="16,0,0,6" />

                    <ItemsControl x:Name="WorkspacesList" Margin="8,0,8,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource WorkspaceItemButton}"
                                        Click="SwitchWorkspace_Click" Tag="{Binding Id}">
                                    <Grid Width="230">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" CornerRadius="14"
                                                    Background="{DynamicResource ThemeCard}" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Initial}"
                                                           Foreground="White" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ThemeTextPrimary}"
                                                       FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="&#x2713;" Foreground="#007CEC"
                                                   FontSize="14" FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Divider -->
                    <Border Height="1" Background="{DynamicResource ThemeHover}" Margin="12,6" />

                    <!-- Logout -->
                    <Button Style="{StaticResource SidebarButton}" Click="Logout_Click"
                            Margin="8,0,8,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2192;" Foreground="#FF4B59" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Logout" Foreground="#FF4B59" FontSize="13" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
