<Window x:Class="VE.Windows.Views.FloatingWindow.FloatingPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VE.Windows.Views.FloatingWindow"
        Title="VE"
        Width="720" Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="False"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">

    <Grid Margin="8">
        <!-- Shadow layer (separate so Effect doesn't break child hit-testing) -->
        <Border CornerRadius="12" Background="#1A1A1A">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.5" ShadowDepth="4" />
            </Border.Effect>
        </Border>

        <!-- Interactive content layer (no Effect applied here) -->
        <Border x:Name="WindowBorder" CornerRadius="12" Background="#1A1A1A"
                BorderBrush="#33FFFFFF" BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <!-- Close button (top-right corner) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="#FF4B59" CornerRadius="0,12,0,8"
                        Padding="10,6" Cursor="Hand" Panel.ZIndex="10"
                        MouseLeftButtonDown="CloseButton_MouseDown">
                    <TextBlock Text="&#x2715;" Foreground="White" FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- Content Area -->
                <local:ChatView x:Name="ChatContent" />
            </Grid>
        </Border>
    </Grid>
</Window>
