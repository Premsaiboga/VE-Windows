<UserControl x:Class="VE.Windows.Views.FloatingWindow.RoutinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Header -->
        <Grid VerticalAlignment="Top" Margin="24,16,24,0">
            <TextBlock Text="Routines" Foreground="White" FontSize="20"
                       FontWeight="Bold" VerticalAlignment="Center" />
            <Button HorizontalAlignment="Right" Style="{StaticResource VEButton}"
                    Padding="16,8" Click="CreateRoutine_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F504;" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Create New Routine" FontSize="13" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Empty State — dashed card -->
        <Border x:Name="EmptyState"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="320" Padding="40,36"
                CornerRadius="12"
                BorderThickness="2"
                Background="#0DFFFFFF">
            <Border.BorderBrush>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Rectangle Width="320" Height="180"
                                   Stroke="#55FFFFFF" StrokeThickness="2"
                                   StrokeDashArray="6 4"
                                   RadiusX="12" RadiusY="12" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="+" Foreground="#007CEC" FontSize="24"
                           HorizontalAlignment="Center" Margin="0,0,0,10" />
                <TextBlock Text="Create New Routine" Foreground="White"
                           FontSize="15" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock Text="Build your own routine from scratch"
                           Foreground="#878E92" FontSize="12"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
