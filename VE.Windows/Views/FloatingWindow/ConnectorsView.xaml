<UserControl x:Class="VE.Windows.Views.FloatingWindow.ConnectorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8">
                <!-- Loading -->
                <TextBlock x:Name="LoadingText" Text="Loading connectors..."
                           Foreground="#878E92" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,40,0,0" />

                <!-- Connected Integrations -->
                <StackPanel x:Name="ConnectedSection" Visibility="Collapsed">
                    <TextBlock Text="Connected" Foreground="#878E92" FontSize="11"
                               FontWeight="SemiBold" Margin="0,8,0,6" />
                    <ItemsControl x:Name="ConnectedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0DFFFFFF" CornerRadius="8"
                                        Padding="12,10" Margin="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="#F4F5F5"
                                                       FontSize="13" FontWeight="Medium" />
                                            <TextBlock Text="{Binding Email}" Foreground="#878E92"
                                                       FontSize="11" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                                   Foreground="#4CAF50" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <Button Grid.Column="2" Content="Disconnect"
                                                FontSize="10" Foreground="#FF4444"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2"
                                                Click="Disconnect_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Separator -->
                <Border x:Name="Separator" Height="1" Background="#1AFFFFFF"
                        Margin="0,12" Visibility="Collapsed" />

                <!-- Available Integrations -->
                <StackPanel x:Name="AvailableSection" Visibility="Collapsed">
                    <TextBlock Text="Available Integrations" Foreground="#878E92" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ItemsControl x:Name="AvailableList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D007CEC" CornerRadius="8"
                                        Padding="12,10" Margin="0,3"
                                        Cursor="Hand" MouseLeftButtonUp="ConnectIntegration_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Foreground="#F4F5F5"
                                                       FontSize="13" FontWeight="Medium" />
                                            <TextBlock Text="{Binding Description}" Foreground="#878E92"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="Connect &#x203A;"
                                                   Foreground="#007CEC" FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
