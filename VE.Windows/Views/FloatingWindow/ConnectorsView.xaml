<UserControl x:Class="VE.Windows.Views.FloatingWindow.ConnectorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,16">

                <!-- Private Integrations Header -->
                <Grid Margin="0,0,0,16">
                    <TextBlock Text="Private Integrations" Foreground="{DynamicResource ThemeTextPrimary}"
                               FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <Border HorizontalAlignment="Right" Background="{DynamicResource ThemeCard}"
                            CornerRadius="8" BorderBrush="{DynamicResource ThemeBorderMedium}"
                            BorderThickness="1" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Private" Foreground="{DynamicResource ThemeTextPrimary}"
                                       FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text=" &#x25BE;" Foreground="{DynamicResource ThemeTextSecondary}"
                                       FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Loading -->
                <TextBlock x:Name="LoadingText" Text="Loading connectors..."
                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,40,0,0" />

                <!-- Connected Section -->
                <StackPanel x:Name="ConnectedSection" Visibility="Collapsed">
                    <ItemsControl x:Name="ConnectedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="10"
                                        Padding="14,12" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="8" Margin="0,0,12,0"
                                                Background="{Binding IconBackground}">
                                            <TextBlock Text="{Binding IconLetter}"
                                                       Foreground="White" FontSize="16"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource ThemeTextPrimary}"
                                                       FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="{Binding Email}" Foreground="{DynamicResource ThemeTextSecondary}"
                                                       FontSize="11" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                                   Foreground="#4CAF50" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <Button Grid.Column="3" Content="Disconnect"
                                                FontSize="10" Foreground="#FF4444"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2"
                                                Click="Disconnect_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- No connected integrations (empty state) -->
                <StackPanel x:Name="EmptyConnectedState" Visibility="Collapsed"
                            HorizontalAlignment="Center" Margin="0,30,0,30">
                    <TextBlock Text="&#x1F517;" FontSize="36" Foreground="{DynamicResource ThemeTextMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="No connected integrations" Foreground="{DynamicResource ThemeTextSecondary}"
                               FontSize="13" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Available Integrations -->
                <StackPanel x:Name="AvailableSection" Visibility="Collapsed">
                    <TextBlock Text="Available Integrations" Foreground="{DynamicResource ThemeTextPrimary}"
                               FontSize="16" FontWeight="Bold" Margin="0,8,0,12" />

                    <!-- Search Bar -->
                    <Border Background="{DynamicResource ThemeCard}" CornerRadius="8"
                            BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                            Padding="4,0" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"
                                       Margin="10,0,8,0" />
                            <TextBox x:Name="SearchBox" Grid.Column="1"
                                     Background="Transparent" Foreground="{DynamicResource ThemeTextPrimary}"
                                     FontSize="13" BorderThickness="0"
                                     Padding="4,10" CaretBrush="{DynamicResource ThemeTextPrimary}"
                                     TextChanged="SearchBox_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <TextBlock x:Name="ph" Text="Search"
                                                                   Foreground="{DynamicResource ThemeTextMuted}" FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   Margin="6,0,0,0"
                                                                   Visibility="Collapsed" />
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      VerticalAlignment="Center" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter TargetName="ph"
                                                                    Property="Visibility"
                                                                    Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Integration Items -->
                    <ItemsControl x:Name="AvailableList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="10"
                                        Padding="14,12" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- App Icon -->
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="8" Margin="0,0,12,0"
                                                Background="{Binding IconBackground}">
                                            <TextBlock Text="{Binding IconLetter}"
                                                       Foreground="White" FontSize="16"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Name -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Foreground="{DynamicResource ThemeTextPrimary}" FontSize="14"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center" />

                                        <!-- Connect Button -->
                                        <Border Grid.Column="2" Background="#007CEC"
                                                CornerRadius="16" Padding="20,7"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="ConnectIntegration_Click">
                                            <TextBlock Text="Connect" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
