<UserControl x:Class="VE.Windows.Views.FloatingWindow.PredictionView2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:VE.Windows.Views.FloatingWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
                BorderBrush="#1AFFFFFF">
            <TextBlock Text="Prediction History" Foreground="White" FontSize="16"
                       FontWeight="SemiBold" />
        </Border>

        <!-- Logs List -->
        <Grid Grid.Row="1">
            <TextBlock x:Name="LoadingText" Text="Loading predictions..."
                       Foreground="#878E92" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,40,0,0" />

            <TextBlock x:Name="EmptyText" Text="No prediction history yet"
                       Foreground="#878E92" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,40,0,0"
                       Visibility="Collapsed" />

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LogsList" Margin="8,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0DFFFFFF" CornerRadius="8"
                                    Padding="12,10" Margin="0,3">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="{Binding App}" Foreground="#007CEC"
                                                   FontSize="10" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding FormattedDate}" Foreground="#555"
                                                   FontSize="10" HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Text="{Binding Query}" Foreground="#F4F5F5"
                                               FontSize="12" TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding Query, Converter={x:Static local:StringToVisConverter.Instance}}" />
                                    <TextBlock Text="{Binding Response}" Foreground="#CCC"
                                               FontSize="11" TextWrapping="Wrap"
                                               MaxHeight="60" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
