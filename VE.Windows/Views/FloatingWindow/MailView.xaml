<UserControl x:Class="VE.Windows.Views.FloatingWindow.MailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8">
                <!-- Loading -->
                <TextBlock x:Name="LoadingText" Text="Loading email settings..."
                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,40,0,0" />

                <!-- ═══ NO ACCOUNT STATE ═══ -->
                <StackPanel x:Name="NoAccountPanel" Visibility="Collapsed"
                            Margin="0,40,0,0">
                    <!-- Title -->
                    <TextBlock Text="No Email connected" Foreground="{DynamicResource ThemeTextPrimary}"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,10" />

                    <!-- Subtitle -->
                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                               Margin="0,0,0,30">
                        <Run Text="Connect Gmail or Outlook  to enable Intent email," />
                        <LineBreak />
                        <Run Text="and Auto draft replies, Auto categories" />
                    </TextBlock>

                    <!-- Gmail + Outlook Cards -->
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="340" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" MaxWidth="340" />
                        </Grid.ColumnDefinitions>

                        <!-- Gmail Card -->
                        <Border Grid.Column="0" Background="{DynamicResource ThemeCard}" CornerRadius="12"
                                BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                Padding="20,20,20,18">
                            <StackPanel>
                                <!-- Gmail Icon -->
                                <Border Width="44" Height="44" CornerRadius="8"
                                        Background="{DynamicResource ThemeHover}" HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <TextBlock Text="M" FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#EA4335" Offset="0" />
                                                <GradientStop Color="#FBBC05" Offset="0.5" />
                                                <GradientStop Color="#34A853" Offset="0.75" />
                                                <GradientStop Color="#4285F4" Offset="1" />
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>

                                <TextBlock Text="Gmail" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="16"
                                           FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Easily connect with Gmail to sync your emails and streamline communication."
                                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,18" />
                                <Button Content="Connect" Style="{StaticResource VEButton}"
                                        Padding="18,8" HorizontalAlignment="Left"
                                        Click="ConnectGmail_Click" />
                            </StackPanel>
                        </Border>

                        <!-- Outlook Card -->
                        <Border Grid.Column="2" Background="{DynamicResource ThemeCard}" CornerRadius="12"
                                BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                Padding="20,20,20,18">
                            <StackPanel>
                                <!-- Outlook Icon -->
                                <Border Width="44" Height="44" CornerRadius="8"
                                        Background="#1A0078D4" HorizontalAlignment="Left"
                                        Margin="0,0,0,14">
                                    <TextBlock Text="O" FontSize="22" FontWeight="Bold"
                                               Foreground="#0078D4"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <TextBlock Text="Outlook" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="16"
                                           FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Easily connect with Outlook to sync your emails and streamline communication."
                                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,0,0,18" />
                                <Button Content="Connect" Style="{StaticResource VEButton}"
                                        Padding="18,8" HorizontalAlignment="Left"
                                        Click="ConnectOutlook_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ═══ SETTINGS (when account connected) ═══ -->
                <StackPanel x:Name="SettingsPanel" Visibility="Collapsed">
                    <!-- Account Selector -->
                    <ComboBox x:Name="AccountSelector" Margin="0,8,0,12"
                              Background="{DynamicResource ThemeCard}" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                              SelectionChanged="Account_Changed" />

                    <!-- Toggle Cards -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0D007CEC" CornerRadius="8" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="Intent Email" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                           FontWeight="Medium" />
                                <CheckBox x:Name="IntentEmailToggle" Content="Enabled"
                                          Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11" Margin="0,4,0,0"
                                          Checked="Toggle_Changed" Unchecked="Toggle_Changed" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#0DFF9800" CornerRadius="8" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="Proactive Emails" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                           FontWeight="Medium" />
                                <CheckBox x:Name="ProactiveToggle" Content="Enabled"
                                          Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11" Margin="0,4,0,0"
                                          Checked="Toggle_Changed" Unchecked="Toggle_Changed" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Auto Categories -->
                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="8" Padding="12,10"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Auto Categories" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                       FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ItemsControl x:Name="CategoriesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" Foreground="{DynamicResource ThemeTextBody}" FontSize="12"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  Margin="0,3" Checked="Category_Changed"
                                                  Unchecked="Category_Changed" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Draft Settings -->
                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="8" Padding="12,10"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Draft Settings" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                       FontWeight="SemiBold" Margin="0,0,0,8" />

                            <CheckBox x:Name="DraftRepliesToggle" Content="Auto Draft Replies"
                                      Foreground="{DynamicResource ThemeTextBody}" FontSize="12" Margin="0,0,0,8"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed" />

                            <TextBlock Text="Reply Frequency" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                       Margin="0,4,0,2" />
                            <ComboBox x:Name="ReplyFrequencyCombo" FontSize="11"
                                      Background="{DynamicResource ThemeCard}" Foreground="{DynamicResource ThemeTextPrimary}"
                                      SelectionChanged="Setting_Changed">
                                <ComboBoxItem Content="Reply to almost everything" />
                                <ComboBoxItem Content="Reply when there's something new" />
                                <ComboBoxItem Content="Reply if it feels expected" />
                                <ComboBoxItem Content="Only reply to direct questions" />
                            </ComboBox>

                            <TextBlock Text="Marketing Filter" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                       Margin="0,8,0,2" />
                            <ComboBox x:Name="MarketingFilterCombo" FontSize="11"
                                      Background="{DynamicResource ThemeCard}" Foreground="{DynamicResource ThemeTextPrimary}"
                                      SelectionChanged="Setting_Changed">
                                <ComboBoxItem Content="Just obvious sales outreach" />
                                <ComboBoxItem Content="Cold emails and unknown senders" />
                                <ComboBoxItem Content="Cold emails, unknown senders, newsletters" />
                                <ComboBoxItem Content="Anything not directly useful" />
                            </ComboBox>

                            <TextBlock Text="Draft Instructions" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                       Margin="0,12,0,4" />
                            <TextBox x:Name="DraftPromptBox" Height="100"
                                     Background="{DynamicResource ThemeBg2}" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                     Padding="8" VerticalScrollBarVisibility="Auto"
                                     TextChanged="Prompt_Changed" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
