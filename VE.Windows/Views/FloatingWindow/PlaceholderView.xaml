<UserControl x:Class="VE.Windows.Views.FloatingWindow.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock x:Name="TitleText" Text="Coming Soon"
                   Foreground="#878E92" FontSize="18"
                   HorizontalAlignment="Center" Margin="0,0,0,8" />
        <TextBlock x:Name="SubtitleText" Text="This feature will be available soon"
                   Foreground="#555" FontSize="13"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />
    </StackPanel>
</UserControl>
