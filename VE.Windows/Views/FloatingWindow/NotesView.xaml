<UserControl x:Class="VE.Windows.Views.FloatingWindow.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
                BorderBrush="#1AFFFFFF">
            <Grid>
                <TextBlock Text="Meeting Notes"
                           Foreground="White" FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button x:Name="NewMeetingBtn" Content="+ Quick Note"
                        HorizontalAlignment="Right"
                        Style="{StaticResource VEButton}"
                        Padding="12,6"
                        Click="NewMeeting_Click" />
            </Grid>
        </Border>

        <!-- Active Meeting Banner -->
        <Border x:Name="ActiveMeetingBanner" Grid.Row="1"
                Background="#1A007CEC" Padding="12,10"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#FF4444"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock x:Name="MeetingDuration" Grid.Column="1"
                           Text="Recording..." Foreground="#007CEC"
                           FontSize="13" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Pause"
                        Style="{StaticResource VEGhostButton}"
                        Click="PauseMeeting_Click" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="Stop"
                        Style="{StaticResource VEButton}"
                        Padding="12,4"
                        Click="StopMeeting_Click" />
            </Grid>
        </Border>

        <!-- Live Transcription -->
        <ScrollViewer x:Name="TranscriptionScroll" Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,8">
            <StackPanel>
                <!-- Welcome when no meetings -->
                <StackPanel x:Name="WelcomePanel"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,80,0,0">
                    <TextBlock Text="Meeting Notes"
                               Foreground="#878E92" FontSize="18"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="Start a Quick Note to capture&#x0a;and transcribe your meetings"
                               Foreground="#555" FontSize="13"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock Text="Double-tap F1 to start"
                               Foreground="#555" FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />
                </StackPanel>

                <!-- Transcription items -->
                <ItemsControl x:Name="TranscriptionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,2,0,2" Padding="8,6"
                                    Background="#0DFFFFFF" CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="{Binding Speaker}"
                                               Foreground="#007CEC" FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="#F4F5F5" FontSize="13"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
