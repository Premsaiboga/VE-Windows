<UserControl x:Class="VE.Windows.Views.FloatingWindow.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Tab button style for Summary/Transcript/Analytics -->
        <Style x:Key="DetailTabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#878E92" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Meetings List View -->
        <Grid x:Name="ListPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
                    BorderBrush="#1AFFFFFF">
                <Grid>
                    <TextBlock Text="Meeting Notes"
                               Foreground="White" FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button x:Name="NewMeetingBtn" Content="+ Quick Note"
                            HorizontalAlignment="Right"
                            Style="{StaticResource VEButton}"
                            Padding="12,6"
                            Click="NewMeeting_Click" />
                </Grid>
            </Border>

            <!-- Active Meeting Banner -->
            <Border x:Name="ActiveMeetingBanner" Grid.Row="1"
                    Background="#1A007CEC" Padding="12,10"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#FF4444"
                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="MeetingDuration" Grid.Column="1"
                               Text="Recording..." Foreground="#007CEC"
                               FontSize="13" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="Pause"
                            Style="{StaticResource VEGhostButton}"
                            Click="PauseMeeting_Click" Margin="0,0,8,0" />
                    <Button Grid.Column="3" Content="Stop"
                            Style="{StaticResource VEButton}"
                            Padding="12,4"
                            Click="StopMeeting_Click" />
                </Grid>
            </Border>

            <!-- Meetings List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          x:Name="MeetingsScroll"
                          ScrollChanged="MeetingsScroll_ScrollChanged">
                <StackPanel Margin="0,0,0,8">
                    <!-- Loading indicator -->
                    <TextBlock x:Name="LoadingText" Text="Loading meetings..."
                               Foreground="#878E92" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,40,0,0"
                               Visibility="Collapsed" />

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyPanel" Visibility="Collapsed"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="0,80,0,0">
                        <TextBlock Text="No Meetings Yet"
                                   Foreground="#878E92" FontSize="18"
                                   HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="Start a Quick Note to capture&#x0a;and transcribe your meetings"
                                   Foreground="#555" FontSize="13"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <!-- Meeting groups by date -->
                    <ItemsControl x:Name="MeetingsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,4">
                                    <!-- Date header -->
                                    <TextBlock Text="{Binding DateHeader}"
                                               Foreground="#878E92" FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="16,12,16,4" />

                                    <!-- Meetings in this group -->
                                    <ItemsControl ItemsSource="{Binding Meetings}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="8,2" Padding="12,10"
                                                        Background="#0DFFFFFF" CornerRadius="8"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="Meeting_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="#F4F5F5" FontSize="13"
                                                                       FontWeight="Medium"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding FormattedTime}"
                                                                       Foreground="#666" FontSize="11"
                                                                       Margin="0,2,0,0" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="&#x203A;"
                                                                   Foreground="#555" FontSize="18"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Load more indicator -->
                    <TextBlock x:Name="LoadMoreText" Text="Loading more..."
                               Foreground="#878E92" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,8,0,8"
                               Visibility="Collapsed" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Meeting Detail View -->
        <Grid x:Name="DetailPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Detail Header with back button -->
            <Border Grid.Row="0" Padding="12,10" BorderThickness="0,0,0,1"
                    BorderBrush="#1AFFFFFF">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="&#x2190; Back"
                            Foreground="#007CEC" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" FontSize="13"
                            Click="BackToList_Click" Padding="4,2" />
                    <TextBlock x:Name="DetailTitle" Grid.Column="1"
                               Foreground="White" FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="8,0,0,0" />
                </Grid>
            </Border>

            <!-- Detail Tabs: Summary | Transcript | Analytics -->
            <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="#1AFFFFFF">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,4,0,0">
                    <Button x:Name="TabSummary" Content="Summary"
                            Style="{StaticResource DetailTabButton}"
                            Tag="Summary" Click="DetailTab_Click" />
                    <Button x:Name="TabTranscript" Content="Transcript"
                            Style="{StaticResource DetailTabButton}"
                            Tag="Transcript" Click="DetailTab_Click" />
                    <Button x:Name="TabAnalytics" Content="Analytics"
                            Style="{StaticResource DetailTabButton}"
                            Tag="Analytics" Click="DetailTab_Click" />
                </StackPanel>
            </Border>

            <!-- Detail Content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16,8">
                <Grid>
                    <!-- Summary Tab -->
                    <StackPanel x:Name="SummaryContent" Visibility="Visible">
                        <TextBlock x:Name="SummaryLoading" Text="Loading summary..."
                                   Foreground="#878E92" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,40,0,0" />

                        <StackPanel x:Name="SummaryData" Visibility="Collapsed">
                            <!-- Meeting info -->
                            <TextBlock x:Name="SummaryDate" Foreground="#878E92" FontSize="11"
                                       Margin="0,8,0,12" />

                            <!-- Summary text -->
                            <TextBlock x:Name="SummaryText" Foreground="#F4F5F5" FontSize="13"
                                       TextWrapping="Wrap" Margin="0,0,0,16" />

                            <!-- Action Items -->
                            <TextBlock x:Name="ActionItemsHeader" Text="Action Items"
                                       Foreground="#007CEC" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6" Visibility="Collapsed" />
                            <ItemsControl x:Name="ActionItemsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="&#x2022;" Foreground="#007CEC" FontSize="13"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Text}" Foreground="#DDD" FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Decisions -->
                            <TextBlock x:Name="DecisionsHeader" Text="Decisions"
                                       Foreground="#007CEC" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,12,0,6" Visibility="Collapsed" />
                            <ItemsControl x:Name="DecisionsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="&#x2022;" Foreground="#4CAF50" FontSize="13"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Text}" Foreground="#DDD" FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Key Points / Highlights -->
                            <TextBlock x:Name="HighlightsHeader" Text="Highlights"
                                       Foreground="#007CEC" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,12,0,6" Visibility="Collapsed" />
                            <ItemsControl x:Name="HighlightsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0DFFFFFF" CornerRadius="6"
                                                Padding="10,6" Margin="0,2">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Text}" Foreground="#DDD" FontSize="12"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Type}" Foreground="#878E92" FontSize="10"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>

                    <!-- Transcript Tab -->
                    <StackPanel x:Name="TranscriptContent" Visibility="Collapsed">
                        <TextBlock x:Name="TranscriptLoading" Text="Loading transcript..."
                                   Foreground="#878E92" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,40,0,0" />

                        <TextBlock x:Name="TranscriptEmpty" Text="No transcript available"
                                   Foreground="#878E92" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,40,0,0"
                                   Visibility="Collapsed" />

                        <ItemsControl x:Name="TranscriptList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2,0,2" Padding="8,6"
                                            Background="#0DFFFFFF" CornerRadius="6">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding SpeakerName}"
                                                           Foreground="#007CEC" FontSize="11"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FormattedTime}"
                                                           Foreground="#555" FontSize="10"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="{Binding Transcript}"
                                                       Foreground="#F4F5F5" FontSize="13"
                                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Analytics Tab -->
                    <StackPanel x:Name="AnalyticsContent" Visibility="Collapsed">
                        <TextBlock x:Name="AnalyticsLoading" Text="Loading analytics..."
                                   Foreground="#878E92" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,40,0,0" />

                        <StackPanel x:Name="AnalyticsData" Visibility="Collapsed">
                            <!-- Analytics not generated message -->
                            <TextBlock x:Name="AnalyticsNotGenerated"
                                       Text="Analytics not yet generated for this meeting."
                                       Foreground="#878E92" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,20,0,0"
                                       Visibility="Collapsed" />

                            <!-- Chapters -->
                            <TextBlock x:Name="ChaptersHeader" Text="Chapters"
                                       Foreground="#007CEC" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,8,0,6" Visibility="Collapsed" />
                            <ItemsControl x:Name="ChaptersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0DFFFFFF" CornerRadius="6"
                                                Padding="10,8" Margin="0,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="White"
                                                           FontSize="12" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Summary}" Foreground="#CCC"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Open Questions -->
                            <TextBlock x:Name="QuestionsHeader" Text="Open Questions"
                                       Foreground="#FF9800" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,12,0,6" Visibility="Collapsed" />
                            <ItemsControl x:Name="QuestionsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="?" Foreground="#FF9800" FontSize="13"
                                                           FontWeight="Bold" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Text}" Foreground="#DDD" FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Asker}" Foreground="#878E92" FontSize="10"
                                                       Margin="20,0,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Participants -->
                            <TextBlock x:Name="ParticipantsHeader" Text="Participants"
                                       Foreground="#007CEC" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,12,0,6" Visibility="Collapsed" />
                            <ItemsControl x:Name="ParticipantsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0DFFFFFF" CornerRadius="6"
                                                Padding="10,6" Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           Foreground="#F4F5F5" FontSize="12" />
                                                <TextBlock Grid.Column="1" Foreground="#878E92" FontSize="11"
                                                           Text="{Binding TalkTimePercentage, StringFormat={}{0}% talk time}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>