<UserControl x:Class="VE.Windows.Views.FloatingWindow.SharedWithMeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content area -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: Title + Dropdown -->
            <Grid Grid.Row="0" Margin="16,12,16,12">
                <TextBlock Text="Shared with me" Foreground="{DynamicResource ThemeTextPrimary}"
                           FontSize="18" FontWeight="Medium" VerticalAlignment="Center" />

                <!-- Dropdown pill -->
                <Border HorizontalAlignment="Right" CornerRadius="100"
                        Background="{DynamicResource ThemeCard}" Padding="14,6"
                        Cursor="Hand" MouseLeftButtonDown="DropdownPill_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="DropdownLabel" Text="Notes" FontSize="14" FontWeight="Medium"
                                   Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,6,0" />
                        <TextBlock x:Name="DropdownChevron" Text="&#x25BE;" FontSize="12"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Dropdown menu -->
                <Border x:Name="DropdownMenu" Visibility="Collapsed"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,40,0,0" Width="140"
                        Background="{DynamicResource ThemeCard}" CornerRadius="8"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0.5"
                        Panel.ZIndex="100">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="8" ShadowDepth="4" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Notes" FontSize="14" Padding="16,10" Cursor="Hand"
                                   Foreground="{DynamicResource ThemeTextPrimary}"
                                   MouseLeftButtonDown="DropdownItem_Notes" />
                        <TextBlock Text="Chats" FontSize="14" Padding="16,10" Cursor="Hand"
                                   Foreground="{DynamicResource ThemeTextPrimary}"
                                   MouseLeftButtonDown="DropdownItem_Chats" />
                        <TextBlock Text="Files" FontSize="14" Padding="16,10" Cursor="Hand"
                                   Foreground="{DynamicResource ThemeTextPrimary}"
                                   MouseLeftButtonDown="DropdownItem_Files" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Notes tab content -->
            <Grid x:Name="NotesContent" Grid.Row="1">
                <!-- Shimmer loading -->
                <StackPanel x:Name="ShimmerPanel" Margin="16,0" Visibility="Collapsed">
                    <Border Background="{DynamicResource ThemeCard}" Width="80" Height="13"
                            CornerRadius="4" HorizontalAlignment="Left" Margin="0,0,0,8" Opacity="0.6" />
                    <Border Background="{DynamicResource ThemeCard}" CornerRadius="10" Padding="12,4" Margin="0,0,0,4">
                        <StackPanel>
                            <Grid Height="48" Margin="0,4">
                                <Border Background="{DynamicResource ThemeBorder}" Height="14"
                                        CornerRadius="4" HorizontalAlignment="Stretch" Margin="0,0,60,0" Opacity="0.3" />
                            </Grid>
                            <Grid Height="48" Margin="0,4">
                                <Border Background="{DynamicResource ThemeBorder}" Height="14"
                                        CornerRadius="4" HorizontalAlignment="Stretch" Margin="0,0,100,0" Opacity="0.3" />
                            </Grid>
                            <Grid Height="48" Margin="0,4">
                                <Border Background="{DynamicResource ThemeBorder}" Height="14"
                                        CornerRadius="4" HorizontalAlignment="Stretch" Margin="0,0,80,0" Opacity="0.3" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyNotes" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0">
                    <TextBlock Text="&#x1F4DD;" FontSize="48" HorizontalAlignment="Center"
                               Foreground="{DynamicResource ThemeTextSecondary}" Opacity="0.5" Margin="0,0,0,12" />
                    <TextBlock Text="Shared Notes" FontSize="15" FontWeight="Medium"
                               Foreground="{DynamicResource ThemeTextSecondary}"
                               HorizontalAlignment="Center" Margin="0,0,0,6" />
                    <TextBlock Text="Notes shared with you will appear here" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource ThemeTextSecondary}" Opacity="0.7"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Meeting list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,0,16,8">
                        <ItemsControl x:Name="MeetingGroupsList" />

                        <!-- Load More button -->
                        <Button x:Name="LoadMoreBtn" Visibility="Collapsed"
                                HorizontalAlignment="Center" Margin="0,8,0,4"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource ThemeTextSecondary}"
                                FontSize="12" FontWeight="Medium" Cursor="Hand"
                                Click="LoadMore_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="LoadMoreText" Text="Load more" />
                                <TextBlock x:Name="LoadMoreSpinner" Text=" &#x23F3;" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Chats placeholder -->
            <StackPanel x:Name="ChatsPlaceholder" Grid.Row="1" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x1F4AC;" FontSize="48" HorizontalAlignment="Center"
                           Foreground="{DynamicResource ThemeTextSecondary}" Opacity="0.5" Margin="0,0,0,12" />
                <TextBlock Text="Shared Chats" FontSize="15" FontWeight="Medium"
                           Foreground="{DynamicResource ThemeTextSecondary}"
                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock Text="Chats shared with you will appear here" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource ThemeTextSecondary}" Opacity="0.7"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Files placeholder -->
            <StackPanel x:Name="FilesPlaceholder" Grid.Row="1" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x1F4C4;" FontSize="48" HorizontalAlignment="Center"
                           Foreground="{DynamicResource ThemeTextSecondary}" Opacity="0.5" Margin="0,0,0,12" />
                <TextBlock Text="Shared Files" FontSize="15" FontWeight="Medium"
                           Foreground="{DynamicResource ThemeTextSecondary}"
                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock Text="Files shared with you will appear here" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource ThemeTextSecondary}" Opacity="0.7"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Selection bar (visible when items selected) -->
        <Border x:Name="SelectionBar" Grid.Row="1" Visibility="Collapsed"
                Margin="16,4,16,4" Padding="8">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Selected count pill -->
                    <Border Background="{DynamicResource ThemeCard}" CornerRadius="100"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0.5"
                            Padding="12,6" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SelectionCountText" Text="0 selected" FontSize="14" FontWeight="Medium"
                                       Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,8,0" />
                            <TextBlock Text="&#x2715;" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource ThemeTextSecondary}"
                                       Cursor="Hand" VerticalAlignment="Center"
                                       MouseLeftButtonDown="ClearSelection_Click" />
                        </StackPanel>
                    </Border>

                    <!-- Trash button -->
                    <Border x:Name="TrashButton" CornerRadius="100"
                            BorderBrush="#80EF4444" BorderThickness="1"
                            Background="Transparent" Padding="12,6"
                            Cursor="Hand" MouseLeftButtonDown="BulkDelete_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TrashButtonText" Text="Move to trash &#x1F5D1;" FontSize="14"
                                       FontWeight="Medium" Foreground="#EF4444" />
                            <TextBlock x:Name="TrashSpinner" Text=" &#x23F3;" Visibility="Collapsed"
                                       FontSize="14" Foreground="#EF4444" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search bar (always visible for Notes tab) -->
        <Border x:Name="SearchBarBorder" Grid.Row="2" Margin="16,4,16,12"
                CornerRadius="100" Height="44"
                Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0.5">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="12" ShadowDepth="4" />
            </Border.Effect>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="14"
                           Foreground="{DynamicResource ThemeTextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBox x:Name="SearchBox" Grid.Column="1" FontSize="14"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource ThemeTextPrimary}"
                         CaretBrush="{DynamicResource ThemeTextPrimary}"
                         VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged" />
                <!-- Placeholder text -->
                <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" Text="Search Notes"
                           FontSize="14" Foreground="{DynamicResource ThemeTextSecondary}"
                           VerticalAlignment="Center" IsHitTestVisible="False"
                           Margin="2,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
