<UserControl x:Class="VE.Windows.Views.FloatingWindow.RecentChatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ThemeBorder}">
            <TextBlock Text="Recent Chats" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="16"
                       FontWeight="SemiBold" />
        </Border>

        <!-- Chat List -->
        <Grid Grid.Row="1">
            <TextBlock x:Name="LoadingText" Text="Loading chats..."
                       Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,40,0,0" />

            <TextBlock x:Name="EmptyText" Text="No recent chats"
                       Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,40,0,0"
                       Visibility="Collapsed" />

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ScrollViewer_ScrollChanged">
                <StackPanel>
                    <ItemsControl x:Name="ChatsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,2" Padding="12,10"
                                        Background="{DynamicResource ThemeRowBg}" CornerRadius="8"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="Chat_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource ThemeTextPrimary}"
                                                       FontSize="13" FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding FormattedTime}" Foreground="{DynamicResource ThemeTextSecondary}"
                                                       FontSize="11" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="&#x2715;"
                                                Foreground="#FF4444" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="4,2"
                                                Click="DeleteChat_Click"
                                                Opacity="0.5" />
                                        <TextBlock Grid.Column="2" Text="&#x203A;"
                                                   Foreground="{DynamicResource ThemeTextMuted}" FontSize="18"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="LoadMoreText" Text="Loading more..."
                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,8,0,16"
                               Visibility="Collapsed" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
