<UserControl x:Class="VE.Windows.Views.FloatingWindow.IntentModelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SubTabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Sub-Tab Picker -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ThemeBorder}" Padding="0,4,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="TabModel" Content="Model" Tag="Model"
                        Style="{StaticResource SubTabButton}" Click="SubTab_Click" />
                <Button x:Name="TabInstructions" Content="Instructions" Tag="Instructions"
                        Style="{StaticResource SubTabButton}" Click="SubTab_Click" />
                <Button x:Name="TabDictionary" Content="Dictionary" Tag="Dictionary"
                        Style="{StaticResource SubTabButton}" Click="SubTab_Click" />
                <Button x:Name="TabSnippets" Content="Snippets" Tag="Snippets"
                        Style="{StaticResource SubTabButton}" Click="SubTab_Click" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,8">
            <Grid>
                <!-- Model Tab -->
                <StackPanel x:Name="ModelContent" Visibility="Visible">
                    <TextBlock x:Name="ModelLoading" Text="Loading..." Foreground="{DynamicResource ThemeTextSecondary}"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,30,0,0" />
                    <StackPanel x:Name="ModelData" Visibility="Collapsed">
                        <TextBlock Text="Name your Intent model" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                   Margin="0,8,0,4" />
                        <TextBox x:Name="CompanionNameBox" Background="{DynamicResource ThemeBg2}" Foreground="{DynamicResource ThemeTextPrimary}"
                                 FontSize="13" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                 Padding="8,6" TextChanged="Model_Changed" />

                        <TextBlock Text="How AI should behave" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                   Margin="0,16,0,4" />
                        <TextBox x:Name="BehaviourBox" Background="{DynamicResource ThemeBg2}" Foreground="{DynamicResource ThemeTextPrimary}"
                                 FontSize="12" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                 Height="120" TextWrapping="Wrap" AcceptsReturn="True"
                                 Padding="8" VerticalScrollBarVisibility="Auto"
                                 TextChanged="Model_Changed" />

                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Be concise" FontSize="10" Margin="0,0,4,4"
                                    Style="{StaticResource VEGhostButton}" Padding="8,4"
                                    Click="SuggestionChip_Click" />
                            <Button Content="Use technical terms" FontSize="10" Margin="0,0,4,4"
                                    Style="{StaticResource VEGhostButton}" Padding="8,4"
                                    Click="SuggestionChip_Click" />
                            <Button Content="Avoid filler words" FontSize="10" Margin="0,0,4,4"
                                    Style="{StaticResource VEGhostButton}" Padding="8,4"
                                    Click="SuggestionChip_Click" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Instructions Tab -->
                <StackPanel x:Name="InstructionsContent" Visibility="Collapsed">
                    <Grid Margin="0,8,0,8">
                        <TextBlock Text="AI Instructions" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13"
                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="+ Add" Style="{StaticResource VEButton}"
                                Padding="10,4" FontSize="11"
                                HorizontalAlignment="Right"
                                Click="AddInstruction_Click" />
                    </Grid>
                    <TextBlock x:Name="InstructionsLoading" Text="Loading..."
                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,20,0,0" />
                    <ItemsControl x:Name="InstructionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="6"
                                        Padding="10,8" Margin="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Content}" Foreground="{DynamicResource ThemeTextBody}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"
                                                       MaxHeight="36" />
                                            <TextBlock Text="{Binding PlatformDisplay}" Foreground="#007CEC"
                                                       FontSize="10" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="&#x2715;" Foreground="#FF4444"
                                                FontSize="10" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="DeleteInstruction_Click" Padding="4" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Dictionary Tab -->
                <StackPanel x:Name="DictionaryContent" Visibility="Collapsed">
                    <Grid Margin="0,8,0,4">
                        <TextBox x:Name="DictSearchBox" Background="{DynamicResource ThemeBg2}" Foreground="{DynamicResource ThemeTextPrimary}"
                                 FontSize="12" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                 Padding="8,4" Width="200" HorizontalAlignment="Left"
                                 TextChanged="DictSearch_Changed" />
                        <Button Content="+ Add Word" Style="{StaticResource VEButton}"
                                Padding="10,4" FontSize="11"
                                HorizontalAlignment="Right"
                                Click="AddWord_Click" />
                    </Grid>
                    <TextBlock x:Name="DictLoading" Text="Loading..."
                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,20,0,0" />
                    <ItemsControl x:Name="DictionaryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="6"
                                        Padding="10,6" Margin="0,2">
                                    <Grid>
                                        <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource ThemeTextBody}"
                                                   FontSize="12" VerticalAlignment="Center" />
                                        <Button Content="&#x2715;" Foreground="#FF4444" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" HorizontalAlignment="Right"
                                                Click="DeleteWord_Click" Padding="4" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Snippets Tab -->
                <StackPanel x:Name="SnippetsContent" Visibility="Collapsed">
                    <Grid Margin="0,8,0,4">
                        <TextBox x:Name="SnippetSearchBox" Background="{DynamicResource ThemeBg2}" Foreground="{DynamicResource ThemeTextPrimary}"
                                 FontSize="12" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1"
                                 Padding="8,4" Width="200" HorizontalAlignment="Left"
                                 TextChanged="SnippetSearch_Changed" />
                        <Button Content="+ Add Snippet" Style="{StaticResource VEButton}"
                                Padding="10,4" FontSize="11"
                                HorizontalAlignment="Right"
                                Click="AddSnippet_Click" />
                    </Grid>
                    <TextBlock x:Name="SnippetLoading" Text="Loading..."
                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,20,0,0" />
                    <ItemsControl x:Name="SnippetsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="6"
                                        Padding="10,6" Margin="0,2">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Word}" Foreground="#007CEC"
                                                       FontSize="11" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Replacement}" Foreground="{DynamicResource ThemeTextBody}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"
                                                       Margin="0,1,0,0" />
                                        </StackPanel>
                                        <Button Content="&#x2715;" Foreground="#FF4444" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" HorizontalAlignment="Right"
                                                Click="DeleteSnippet_Click" Padding="4" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
