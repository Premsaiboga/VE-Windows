<Window x:Class="VE.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:notch="clr-namespace:VE.Windows.Views.Notch"
        xmlns:converters="clr-namespace:VE.Windows.Converters"
        Title="VE"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />

        <!-- Smooth open animation - slow and fluid -->
        <Storyboard x:Key="OpenAnimation">
            <DoubleAnimation Storyboard.TargetName="NotchBorder"
                             Storyboard.TargetProperty="Width"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="NotchBorder"
                             Storyboard.TargetProperty="Height"
                             Duration="0:0:0.75">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="NotchBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0.85" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Smooth close animation - slow and fluid -->
        <Storyboard x:Key="CloseAnimation">
            <DoubleAnimation Storyboard.TargetName="NotchBorder"
                             Storyboard.TargetProperty="Width"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="NotchBorder"
                             Storyboard.TargetProperty="Height"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <QuarticEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="0,0,0,8">
        <!-- Shadow effect -->
        <Border x:Name="ShadowBorder" Margin="12">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="6" Opacity="0.4" Direction="270" />
            </Border.Effect>
        </Border>

        <!-- Main notch container -->
        <Border x:Name="NotchBorder"
                Width="220" Height="36"
                CornerRadius="0,0,12,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                ClipToBounds="True"
                MouseEnter="NotchBorder_MouseEnter"
                MouseLeave="NotchBorder_MouseLeave">
            <Border.Background>
                <SolidColorBrush x:Name="NotchBg" Color="Black" />
            </Border.Background>

            <!-- Glass border overlay -->
            <Border CornerRadius="0,0,12,12"
                    BorderThickness="0,0,1,1"
                    Padding="0">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0" />
                        <GradientStop Color="#66FFFFFF" Offset="0.5" />
                        <GradientStop Color="#80FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Grid>
                    <!-- Closed state content -->
                    <notch:ClosedNotchView x:Name="ClosedContent"
                                           Visibility="Visible" />

                    <!-- Open state content -->
                    <notch:NotchHomeView x:Name="OpenContent"
                                         Visibility="Collapsed" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>