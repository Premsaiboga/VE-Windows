<UserControl x:Class="VE.Windows.Views.Notch.ClosedNotchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:VE.Windows.Views.Components">

    <UserControl.Resources>
        <Storyboard x:Key="FadeTransition">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="ContentGrid" MinWidth="200" Height="36">
        <!-- Persistent left: green dot + VE logo -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0">
            <Ellipse x:Name="StatusDot"
                     Width="6" Height="6"
                     Fill="#00CA48"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0" />
            <TextBlock Text="VE"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Persistent right: settings gear (no hover background) -->
        <Button x:Name="SettingsButton"
                Content="&#x2699;"
                Foreground="#878E92"
                FontSize="14"
                BorderThickness="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Cursor="Hand"
                Click="SettingsButton_Click"
                Padding="8,0"
                Margin="0,0,8,0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Idle State (shown in center area, nothing extra needed) -->
        <Grid x:Name="IdleContent" Visibility="Visible" />

        <!-- Welcome Message -->
        <Grid x:Name="WelcomeContent" Visibility="Collapsed">
            <TextBlock Text="Welcome to VE"
                       Foreground="White"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Prediction Waiting State -->
        <Grid x:Name="PredictionWaitingContent" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Predicting"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <components:SmoothDotLoader x:Name="PredictionLoader"
                                            DotColor="White"
                                            DotSize="4" />
            </StackPanel>
        </Grid>

        <!-- Prediction Streaming State (for hold/voice predictions) -->
        <Grid x:Name="PredictionStreamingContent" Visibility="Collapsed">
            <TextBlock x:Name="PredictionStreamText"
                       Text=""
                       Foreground="White"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MaxWidth="140"
                       Margin="40,0" />
        </Grid>

        <!-- Prediction Success State -->
        <Grid x:Name="PredictionSuccessContent" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="&#x2713;"
                           Foreground="#00CA48"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="Pasted"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Dictation Waiting State -->
        <Grid x:Name="DictationWaitingContent" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Listening"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <components:AudioWaveBars x:Name="DictationWaveBars"
                                          BarColor="#007CEC"
                                          BarWidth="3"
                                          BarCount="5" />
            </StackPanel>
        </Grid>

        <!-- Dictation Success State -->
        <Grid x:Name="DictationSuccessContent" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="&#x2713;"
                           Foreground="#00CA48"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <TextBlock Text="Transcribed"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Update Banner -->
        <Grid x:Name="UpdateBannerContent" Visibility="Collapsed">
            <TextBlock Text="Update available - Click to update"
                       Foreground="#FFC600"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Error State (shown in notch briefly) -->
        <Grid x:Name="ErrorContent" Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       Text="Error"
                       Foreground="#FF4B59"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Recording Indicator -->
        <Grid x:Name="RecordingIndicator" Visibility="Collapsed"
              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0">
            <Ellipse Width="8" Height="8" Fill="#FF4B59">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.3" Duration="0:0:0.8"
                                                 AutoReverse="True" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </Grid>
    </Grid>
</UserControl>
