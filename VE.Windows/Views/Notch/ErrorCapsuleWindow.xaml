<Window x:Class="VE.Windows.Views.Notch.ErrorCapsuleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Width="300" Height="36"
        ResizeMode="NoResize">

    <Border CornerRadius="18" Background="{DynamicResource ThemeCard}" BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="0.5"
            Padding="16,0" Margin="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.4" />
        </Border.Effect>
        <Grid>
            <TextBlock x:Name="ErrorText"
                       Text="Error"
                       Foreground="#FF4B59"
                       FontSize="12"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="260" />
        </Grid>
    </Border>
</Window>
