<UserControl x:Class="VE.Windows.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="300">
            <!-- VE Logo -->
            <TextBlock Text="VE"
                       Foreground="{DynamicResource ThemeTextPrimary}"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <TextBlock Text="AI-Powered Assistant"
                       Foreground="{DynamicResource ThemeTextSecondary}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32" />

            <!-- Sign in with Microsoft -->
            <Button x:Name="MicrosoftButton"
                    Click="MicrosoftButton_Click"
                    Cursor="Hand"
                    Margin="0,0,0,12">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#007CEC" CornerRadius="8"
                                Padding="16,10" MinWidth="240">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                           Foreground="White" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Sign in with Microsoft"
                                           Foreground="White" FontSize="14"
                                           FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Sign in with Google -->
            <Button x:Name="GoogleButton"
                    Click="GoogleButton_Click"
                    Cursor="Hand"
                    Margin="0,0,0,24">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="White" CornerRadius="8"
                                Padding="16,10" MinWidth="240">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="G" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush>
                                            <GradientStop Color="#4285F4" Offset="0" />
                                            <GradientStop Color="#EA4335" Offset="0.33" />
                                            <GradientStop Color="#FBBC05" Offset="0.66" />
                                            <GradientStop Color="#34A853" Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text="Sign in with Google"
                                           Foreground="#333333" FontSize="14"
                                           FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Loading Spinner -->
            <StackPanel x:Name="LoadingSpinner" Visibility="Collapsed"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="Signing in..."
                           Foreground="{DynamicResource ThemeTextSecondary}" FontSize="13"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Terms & Privacy -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Foreground="{DynamicResource ThemeTextSecondary}" FontSize="10">
                    <Hyperlink x:Name="TermsLink" Click="TermsLink_Click"
                               Foreground="{DynamicResource ThemeTextSecondary}" TextDecorations="Underline">
                        Terms of Service
                    </Hyperlink>
                </TextBlock>
                <TextBlock Text=" · " Foreground="{DynamicResource ThemeTextSecondary}" FontSize="10" />
                <TextBlock Foreground="{DynamicResource ThemeTextSecondary}" FontSize="10">
                    <Hyperlink x:Name="PrivacyLink" Click="PrivacyLink_Click"
                               Foreground="{DynamicResource ThemeTextSecondary}" TextDecorations="Underline">
                        Privacy Policy
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
