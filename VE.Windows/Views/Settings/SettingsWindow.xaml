<Window x:Class="VE.Windows.Views.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VE Settings"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeBg}">

    <Window.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveSidebarButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}">
            <Setter Property="Background" Value="#1A007CEC" />
            <Setter Property="Foreground" Value="#007CEC" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,16">
                <StackPanel>
                    <!-- Apps Section -->
                    <TextBlock Text="APPS" Foreground="{DynamicResource ThemeTextMuted}" FontSize="10" FontWeight="SemiBold"
                               Margin="16,0,0,8" />
                    <Button Content="Home" Tag="home" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Chat" Tag="chat" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Notes" Tag="notes" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Connectors" Tag="connectors" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Knowledge" Tag="knowledge" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Instructions" Tag="instructions" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Memory" Tag="memory" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Voice" Tag="voice" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Prediction Logs" Tag="predictionlogs" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Dictation Logs" Tag="dictationlogs" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />

                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorder}" Margin="16,12" />

                    <!-- Settings Section -->
                    <TextBlock Text="SETTINGS" Foreground="{DynamicResource ThemeTextMuted}" FontSize="10" FontWeight="SemiBold"
                               Margin="16,0,0,8" />
                    <Button Content="Shortcuts" Tag="shortcuts" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="My Profile" Tag="profile" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Subscription" Tag="subscription" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Workspace" Tag="workspace" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Team Members" Tag="team" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Share &amp; Earn" Tag="share" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />

                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorder}" Margin="16,12" />

                    <Button Content="About" Tag="about" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="Log Out" Foreground="#FF4B59" Tag="logout" Click="SidebarButton_Click" Style="{StaticResource SidebarButton}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource ThemeBorder}" />

        <!-- Content Area -->
        <Grid Grid.Column="2" Margin="24,16">
            <ContentControl x:Name="ContentArea" />
        </Grid>
    </Grid>
</Window>
