<UserControl x:Class="VE.Windows.Views.Components.SmoothDotLoader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="20">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="White" Margin="2,0">
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="Dot1Transform" />
            </Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="Dot1Transform"
                                             Storyboard.TargetProperty="Y"
                                             From="0" To="-6" Duration="0:0:0.4"
                                             AutoReverse="True" BeginTime="0:0:0">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="White" Margin="2,0">
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="Dot2Transform" />
            </Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="Dot2Transform"
                                             Storyboard.TargetProperty="Y"
                                             From="0" To="-6" Duration="0:0:0.4"
                                             AutoReverse="True" BeginTime="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="White" Margin="2,0">
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="Dot3Transform" />
            </Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="Dot3Transform"
                                             Storyboard.TargetProperty="Y"
                                             From="0" To="-6" Duration="0:0:0.4"
                                             AutoReverse="True" BeginTime="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
    </StackPanel>
</UserControl>
